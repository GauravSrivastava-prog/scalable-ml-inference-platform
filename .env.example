# Database
POSTGRES_USER=mlplatform
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mlplatform
DATABASE_URL=postgresql+asyncpg://mlplatform:CHANGE_ME@postgres:5432/mlplatform

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO

# Dataset constraints
MAX_DATASET_SIZE_MB=20
MAX_DATASET_ROWS=100000

# Service ports (host-side)
AUTH_SERVICE_PORT=8001
MODEL_SERVICE_PORT=8002
PREDICTION_SERVICE_PORT=8003
